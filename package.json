{
  "name": "treemux",
  "version": "0.1.0",
  "type": "module",
  "license": "Apache-2.0",
  "bin": {
    "treemux": "./bin/treemux.ts"
  },
  "scripts": {
    "dev": "bun run bin/treemux.ts",
    "build": "bun build --compile bin/treemux.ts --outfile bin/tt && rm -rf bin/native && mkdir -p bin/native && cp -R node_modules/node-pty/prebuilds/. bin/native/ && ln -sf $(pwd)/bin/tt /usr/local/bin/tt",
    "typecheck": "tsc --noEmit",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true"
  },
  "dependencies": {
    "effect": "^3.14.0",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "ink-select-input": "^6.0.0",
    "react": "^18.3.1",
    "node-pty": "^1.1.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/addon-serialize": "^0.14.0",
    "nanoid": "^5.1.5"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "@types/react": "^18.3.0",
    "@types/node": "^22.15.0",
    "bun-types": "latest"
  }
}
